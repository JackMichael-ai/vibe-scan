# VibeScan API — Environment Variables
# Copy to .env and fill in values before starting server

# Database (PostgreSQL)
# Railway: paste the DATABASE_URL from your Railway Postgres plugin
# Supabase: Settings → Database → Connection string (Transaction mode)
DATABASE_URL=postgresql://vibescan_app:password@localhost:5432/vibescan

# Redis (for WebSocket pub/sub and rate limiting)
# Railway: add Redis plugin, paste REDIS_URL
REDIS_URL=redis://localhost:6379

# JWT secret — generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=replace_with_64_byte_random_hex_string

# JWT expiry for node tokens (long — nodes are managed devices)
NODE_TOKEN_EXPIRY=90d

# JWT expiry for user/dashboard tokens
USER_TOKEN_EXPIRY=7d

# Server
PORT=3000
NODE_ENV=production

# CORS — comma-separated list of allowed dashboard origins
ALLOWED_ORIGINS=https://dashboard.vibescan.io,https://app.vibescan.io

# FCM (Firebase Cloud Messaging) — for push notifications to operator phones
# Get from Firebase Console → Project Settings → Service Accounts
FCM_SERVICE_ACCOUNT_KEY={"type":"service_account",...}

# Sentry (optional — error tracking)
SENTRY_DSN=

# Email (optional — alert digest emails)
SMTP_HOST=smtp.sendgrid.net
SMTP_PORT=587
SMTP_USER=apikey
SMTP_PASS=your_sendgrid_api_key
FROM_EMAIL=alerts@vibescan.io
