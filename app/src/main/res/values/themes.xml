<!-- app/src/main/res/values/themes.xml -->
<resources>
    <!-- Base minimalist theme -->
    <style name="Theme.VibeScan" parent="Theme.MaterialComponents.Light.NoActionBar">
        <!-- Primary colors -->
        <item name="colorPrimary">@color/accent_teal</item>
        <item name="colorPrimaryVariant">@color/accent_teal_dark</item>
        <item name="colorOnPrimary">@color/white</item>

        <!-- Secondary colors -->
        <item name="colorSecondary">@color/vibe_blue</item>
        <item name="colorSecondaryVariant">@color/accent_teal_dark</item>
        <item name="colorOnSecondary">@color/white</item>

        <!-- Background colors -->
        <item name="android:windowBackground">@color/background</item>
        <item name="android:colorBackground">@color/background</item>
        <item name="colorSurface">@color/surface</item>
        <item name="colorOnSurface">@color/text_primary</item>

        <!-- Status bar -->
        <item name="android:statusBarColor">@color/background</item>
        <item name="android:windowLightStatusBar">true</item>

        <!-- Navigation bar -->
        <item name="android:navigationBarColor">@color/background</item>
        <item name="android:windowLightNavigationBar">true</item>

        <!-- Text colors -->
        <item name="android:textColorPrimary">@color/text_primary</item>
        <item name="android:textColorSecondary">@color/text_secondary</item>

        <!-- Material components -->
        <item name="textInputStyle">@style/Widget.VibeScan.TextInputLayout</item>
        <item name="materialButtonStyle">@style/Widget.VibeScan.Button</item>
        <item name="materialCardViewStyle">@style/Widget.VibeScan.CardView</item>
    </style>

    <!-- Splash screen theme -->
    <style name="Theme.VibeScan.Splash" parent="Theme.SplashScreen">
        <item name="windowSplashScreenBackground">@color/background</item>
        <item name="windowSplashScreenAnimatedIcon">@mipmap/ic_launcher</item>
        <item name="windowSplashScreenAnimationDuration">300</item>
        <item name="postSplashScreenTheme">@style/Theme.VibeScan</item>
        <item name="android:statusBarColor">@color/background</item>
        <item name="android:navigationBarColor">@color/background</item>
        <item name="android:windowLightStatusBar">true</item>
    </style>

    <!-- Custom TextInputLayout style -->
    <style name="Widget.VibeScan.TextInputLayout" parent="Widget.MaterialComponents.TextInputLayout.OutlinedBox">
        <item name="boxStrokeColor">@color/accent_teal</item>
        <item name="boxStrokeWidth">2dp</item>
        <item name="hintTextColor">@color/accent_teal</item>
        <item name="android:textColorHint">@color/text_secondary</item>
        <item name="boxBackgroundColor">@color/surface</item>
    </style>

    <!-- Custom Button style -->
    <style name="Widget.VibeScan.Button" parent="Widget.MaterialComponents.Button">
        <item name="backgroundTint">@color/accent_teal</item>
        <item name="android:textColor">@color/white</item>
        <item name="cornerRadius">12dp</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:fontFamily">@font/outfit_medium</item>
        <item name="elevation">0dp</item>
        <item name="android:stateListAnimator">@null</item>
    </style>

    <!-- Outlined Button -->
    <style name="Widget.VibeScan.Button.Outlined" parent="Widget.MaterialComponents.Button.OutlinedButton">
        <item name="strokeColor">@color/accent_teal</item>
        <item name="strokeWidth">2dp</item>
        <item name="android:textColor">@color/accent_teal</item>
        <item name="cornerRadius">12dp</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:fontFamily">@font/outfit_medium</item>
    </style>

    <!-- Card view style -->
    <style name="Widget.VibeScan.CardView" parent="Widget.MaterialComponents.CardView">
        <item name="cardBackgroundColor">@color/surface_elevated</item>
        <item name="cardElevation">0dp</item>
        <item name="strokeColor">@color/vibe_border</item>
        <item name="strokeWidth">1dp</item>
        <item name="cardCornerRadius">16dp</item>
    </style>
</resources>